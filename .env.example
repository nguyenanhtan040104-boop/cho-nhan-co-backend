# App
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# Database (thay bằng thông tin PostgreSQL của bạn)
DATABASE_URL="postgresql://admin:password@localhost:5432/cho_nhan_co?schema=public"

# Redis (thay host nếu dùng cloud)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=cho-nhan-co-jwt-secret-key-change-this-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=cho-nhan-co-refresh-secret-key-change-this-in-production
JWT_REFRESH_EXPIRES_IN=7d

# SMS - ESMS.vn (đăng ký tại esms.vn)
ESMS_API_KEY=your_esms_api_key
ESMS_SECRET_KEY=your_esms_secret_key
ESMS_BRAND_NAME=ChNhanC

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM="Chợ Nhân Cơ <no-reply@chonhancu.vn>"

# File Storage - Cloudflare R2 (hoặc AWS S3)
# Tạo account tại cloudflare.com -> R2
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY=your_r2_access_key
R2_SECRET_KEY=your_r2_secret_key
R2_BUCKET=cho-nhan-co
R2_PUBLIC_URL=https://your-r2-public-url.r2.dev

# Hoặc dùng AWS S3 thay thế
# AWS_REGION=ap-southeast-1
# AWS_ACCESS_KEY=xxx
# AWS_SECRET_KEY=xxx
# AWS_BUCKET=cho-nhan-co
